          {"exercise_id":"e020","sets":3,"reps":"15-20","notes":"Feet shoulder-width, controlled"},
          {"exercise_id":"e030","sets":3,"reps":"12-15","notes":"Seated, back supported"},
          {"exercise_id":"e040","sets":3,"reps":"10 each side","notes":"Lower back must stay flat"},
